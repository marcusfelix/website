---
import Layout from "./Layout.astro";
import {
    IconBrandTwitter,
    IconBrandFacebook,
    IconBrandLinkedin,
} from "@tabler/icons-preact";

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
    <section class="flex flex-col gap-20">
        {frontmatter.image && (
            <div class="container mx-auto">
                <img
                    src={frontmatter.image.url}
                    alt={frontmatter.image.alt}
                    class="w-full"
                />
            </div>
        )}
        <article class="flex flex-col gap-12 mx-auto container max-w-3xl">
            <div class="flex flex-col gap-4">
                <h1 class="md:text-6xl text-5xl font-bold tracking-tight">
                    {frontmatter.title}
                </h1>
                <h3 class="md:text-3xl text-2xl text-foreground-500 font-light">
                    {frontmatter.description}
                </h3>
            </div>
            <div class="prose prose-xl">
                <slot />
            </div>
            <div>
                <div class="flex items-center gap-2">
                    <a
                        href={`https://twitter.com/intent/tweet?text=https://marcusfelix.pages.dev${Astro.props.url}`}
                        class="hover:text-foreground-500 transition-colors"
                        target="_blank"
                        aria-label="Share on Twitter"
                    >
                        <IconBrandTwitter />
                    </a>
                    <a
                        href={`https://www.facebook.com/sharer/sharer.php?u=https://marcusfelix.pages.dev${Astro.props.url}`}
                        class="hover:text-foreground-500 transition-colors"
                        target="_blank"
                        aria-label="Share on Facebook"
                    >
                        <IconBrandFacebook />
                    </a>
                    <a
                        href={`https://www.linkedin.com/sharing/share-offsite/?url=https://marcusfelix.pages.dev${Astro.props.url}`}
                        class="hover:text-foreground-500 transition-colors"
                        target="_blank"
                        aria-label="Share on LinkedIn"
                    >
                        <IconBrandLinkedin />
                    </a>
                </div>
                <div class="text-foreground-500 py-4">
                    By {frontmatter.author} @ {
                        new Date(frontmatter.created).toLocaleDateString(
                            "en-US",
                            {
                                year: "numeric",
                                month: "2-digit",
                                day: "2-digit",
                            },
                        )
                    }
                </div>
            </div>
        </article>
    </section>
</Layout>
