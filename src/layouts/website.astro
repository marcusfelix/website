---
import Footer from '../components/footer.astro';
import Header from '../components/header.astro';

export interface Props {
	title: string;
}

const { title, post } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/icon.png" />
		<meta name="generator" content={Astro.generator} />
        <meta name="tags" content="developer, web, frontend, mobile" />
        <meta name="description" content="Hello!, my name is Marcus felix! Front end developer with 10+ years experience on web, mobile and design." />
        <meta name="author" content="Marcus Felix" />
        <meta property="og:title" content="Marcus Felix - Front end developer" />
        <meta property="og:url" content={"https://marcusfelix.page.dev"} />
        <meta property="og:image" content={"https://marcusfelix.page.dev/code-bro.png"} />
        <meta property="og:type" content="website" />
		<title>{title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;700&display=swap" rel="stylesheet">
	</head>
	<body>
        <div class={"container mx-auto flex flex-col gap-10 px-4 max-w-2xl"}>
            <Header/>
            <slot />
            <Footer/>
        </div>
	</body>
</html>
<style is:global>
	body {
		@apply bg-red-600 text-white
	}
</style>
