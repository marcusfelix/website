---
const props = Astro.props;
---

<a 
    href={props.url} 
    class="flex flex-col md:flex-row gap-4 grayscale hover:grayscale-0 transition-all"
>
    <img src={props.image} alt={props.title} class="h-50 md:h-32 object-cover aspect-video" />
    <div class="flex flex-col gap-2 justify-between">
        <div class="flex-row justify-between hidden md:flex">
            <span class="text-lg">{props.index}.</span>
        </div>
        <div class="flex flex-col gap-2">
            <h4 class="text-foreground-500 text-sm uppercase">Article</h4>
            <h2 class="text-2xl font-bold line-clamp-2">{props.title}</h2>
        </div>
    </div>
</a>
