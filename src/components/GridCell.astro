---
import { IconWorld } from "@tabler/icons-preact";

const props = Astro.props;

---

<div class={"p-4 flex flex-col gap-4 group bg-background " + props.class}>
    <div class="text-lg flex justify-between">
        <span>{props.index}.</span>
        {props.cpw && <span class="text-foreground-500 text-sm">{props.cpw} cpw</span>}
    </div>
    <div class="flex flex-col gap-2">
        <h4 class="text-foreground-500 text-sm uppercase">{props.subtitle}</h4>
        <p class="text-lg">{props.title}</p>
        <div>
            {props.url && <a href={props.url} target="_blank" rel="noopener noreferrer" class="">
                <IconWorld size={20} class="text-foreground-200 group-hover:text-foreground-500"/>
            </a>}
        </div>
    </div>
</div>
