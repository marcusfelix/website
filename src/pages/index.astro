---
import Layout from "../layouts/Layout.astro";
import GridCell from "../components/GridCell.astro";
import Post from "../components/Post.astro";
import { IconPlayerPlay } from "@tabler/icons-preact";
import CodeWindow from "../components/CodeWindow.astro";
import LikeButton from "../components/LikeButton";

const posts = await Astro.glob('./articles/*.md');
---

<Layout>
	<section class="container mx-auto flex flex-col gap-20">
		<main class="flex flex-col justify-center">
			<div class="flex flex-row gap-4 items-center">
				<div class="">
					<h1 class="flex-1 font-bold text-8xl text-foreground-900">
						Design oriented code​_
					</h1>
				</div>
				<div class="flex flex-col gap-2">
					<CodeWindow/>
					<div class="flex flex-row px-2">
						<button class="flex gap-2 items-center">
							<IconPlayerPlay size={18}/> Run code
						</button>
					</div>
				</div>
			</div>
		</main>
		<div class="flex flex-col gap-6">
			<div>
				<p class="text-xl text-foreground-500">
					Hi, I'm Marcus. I'm a software developer with a passion for
					technology and a strong background in design. I basically let
					human factors, purpose, and empathy guide my technical skills to
					create digital products that are simple and enjoyable to use.
				</p>
			</div>
			<div class="flex gap-4 items-stretch justify-between">
				<div class="flex gap-4">
					<button class="bg-blue-600 text-blue-100 px-6"
						>GitHub</button
					>
					<div class="flex flex-col text-sm text-foreground-500">
						v2.304 <br /> Release notes
					</div>
				</div>
				<div class="flex gap-4">
					<LikeButton client:load/>
				</div>
				
			</div>
		</div>
		<div>
			<div class="grid grid-cols-4 border gap-px border-foreground-200 bg-foreground-200 rounded-xl overflow-hidden">
				<GridCell
					index={1}
					title="Muun GmbH"
					subtitle="Work"
					url="https://muun.studio"
				/>
				<GridCell
					index={2}	
					title="memoria"
					subtitle="Side project"
					class="col-span-2" 
				/>
				<GridCell
					index={3}
					title="Steely Dan"
					subtitle="Listening"
				/>
				<GridCell
					index={4}
					title="Agent Barney"
					subtitle="Side project"
				/>
				<GridCell
					index={5}
					title="Fluent Forever"
					subtitle="Reading"
					url="https://hardcover.app/books/fluent-forever"
					
				/>
				<GridCell
					index={6}
					title="German A2"
					subtitle="Learning"
				/>
				
				<GridCell
					index={7}
					title="Hytale"
					subtitle="Gaming"
					url="https://hytale.com/"
				/>
			</div>
		</div>

		<div>
			<h2 class="text-3xl font-bold text-foreground-900 mb-6">Articles</h2>
			<div class="grid grid-cols-2 gap-4">
				{posts.map((item, i) => <Post 
					index={i + 1}
					image={item.frontmatter.image.url} 
					slug={(item.file.split("/").at(-1) as string).replace(".md", "")} 
					title={item.frontmatter.title}
					url={`/articles/${(item.file.split("/").at(-1) as string).replace(".md", "")}`}
				/>)}
			</div>
		</div>
	</section>
</Layout>
