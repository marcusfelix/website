---
import Card from "../components/card.astro";
import Website from "../layouts/website.astro";

const data = await Astro.glob('./posts/*.md');
const posts = data.slice(0, 3);
const techs = ["Web", "Typescript", "Dart", "NextJS", "Flutter", "Figma"]
---

<Website title="Marcus Felix - Front end Developer">
	<div class="flex flex-col-reverse gap-10 md:gap-2 md:flex-row items-center">
		<div class="flex flex-col gap-4">
			<h1 class="text-4xl font-semibold">Hello! My name is Marcus Felix!</h1>
			<p class="text-xl text-red-300">Front end developer with 10+ years experience on web, mobile and design.</p>
			<div class="flex flex-wrap gap-2">
				{techs.map((tech) => <span class="bg-red-500 text-xs text-red-100 rounded-full font-semibold px-2 py-1">{tech}</span>)}
			</div>
		</div>
		<div>
			<img src="/code-bro.png" class="max-w-[320px]"/>
		</div>
	</div>
	<div class="flex flex-col gap-4">
		<h2 class="text-2xl font-semibold">Latest posts</h2>
		<div class="grid grid-cols-2 md:grid-cols-3 gap-4">
			{posts.map((post) => <Card 
				data={post.frontmatter}
				href={"/posts/" + post.file.split("/").at(-1)?.split(".").at(0)}
			/>)}
		</div>
	</div>
</Website>
