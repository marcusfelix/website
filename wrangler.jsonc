{
	"main": "dist/_worker.js/index.js",
	"name": "my-astro-app",
	"compatibility_date": "2025-03-25",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
			"binding": "WEBSITE_LIKES_STORE",
			"id": "90017a1a492b42d29e11cc8473440ed2"
		},
		{
			"binding": "SESSION",
			"id": "d925ecee842d4db6900c1b6b1d2128f7"
		}
	]
}